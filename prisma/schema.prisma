generator client {
  provider   = "prisma-client"
  output     = "../generated/prisma"
  engineType = "client"
}

datasource db {
  provider = "postgresql"
}

model Household {
  id            String          @id
  name          String
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  members       Member[]
  tasks         HouseholdTask[]
  shoppingItems ShoppingItem[]
  bonusTransactions BonusTransaction[]
  bonusPurchases BonusPurchase[]
  monthlyReports MonthlyReport[]
}

model Member {
  id             String    @id @default(cuid())
  householdId    String
  telegramUserId String    @unique
  chatId         String    @unique
  firstName      String
  lastName       String?
  username       String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  household      Household @relation(fields: [householdId], references: [id], onDelete: Cascade)
  bonusTransactions BonusTransaction[]
  bonusPurchases BonusPurchase[]

  @@index([householdId])
}

model HouseholdTask {
  id                String    @id @default(cuid())
  householdId       String    @default("default-household")
  title             String
  note              String?
  status            String    @default("open")
  priority          String    @default("normal")
  addedByName       String
  addedByUsername   String?
  addedByTelegramId String?
  deadlineAt        DateTime  @default(dbgenerated("(now() + interval '24 hours')"))
  completedAt       DateTime?
  completedByName   String?
  lastDeadlineReminderAt DateTime?
  penaltyAppliedAt  DateTime?
  penaltyAppliedUnits Int @default(0)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  household         Household @relation(fields: [householdId], references: [id], onDelete: Cascade)
  bonusTransactions BonusTransaction[]

  @@index([householdId, status, createdAt])
  @@index([householdId, status, deadlineAt])
}

model ShoppingItem {
  id                String    @id @default(cuid())
  householdId       String    @default("default-household")
  title             String
  status            String    @default("active")
  urgency           String    @default("soon")
  quantityLabel     String?
  note              String?
  addedByName       String
  addedByUsername   String?
  addedByTelegramId String?
  purchasedAt       DateTime?
  purchasedByName   String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  household         Household @relation(fields: [householdId], references: [id], onDelete: Cascade)

  @@index([householdId, status, createdAt])
}

model BonusTransaction {
  id          String        @id @default(cuid())
  householdId String
  memberId    String
  taskId      String?
  purchaseId  String?
  monthKey    String
  kind        String
  amountUnits Int
  note        String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  household   Household     @relation(fields: [householdId], references: [id], onDelete: Cascade)
  member      Member        @relation(fields: [memberId], references: [id], onDelete: Cascade)
  task        HouseholdTask? @relation(fields: [taskId], references: [id], onDelete: SetNull)
  purchase    BonusPurchase? @relation(fields: [purchaseId], references: [id], onDelete: SetNull)

  @@index([householdId, monthKey, memberId])
  @@index([taskId, kind])
}

model BonusPurchase {
  id          String      @id @default(cuid())
  householdId String
  memberId    String
  monthKey    String
  rewardKey   String
  rewardTitle String
  costUnits   Int
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  household   Household   @relation(fields: [householdId], references: [id], onDelete: Cascade)
  member      Member      @relation(fields: [memberId], references: [id], onDelete: Cascade)
  transactions BonusTransaction[]

  @@index([householdId, monthKey, memberId])
}

model MonthlyReport {
  id            String   @id @default(cuid())
  householdId   String
  monthKey      String
  title         String
  reportBody    String
  sentAt        DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  household     Household @relation(fields: [householdId], references: [id], onDelete: Cascade)

  @@unique([householdId, monthKey])
  @@index([householdId, createdAt])
}
