generator client {
  provider   = "prisma-client"
  output     = "../generated/prisma"
  engineType = "client"
}

datasource db {
  provider = "postgresql"
}

model Household {
  id            String          @id @default(cuid())
  name          String
  revision      Int             @default(0)
  sharedGoalUnits Int           @default(0)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  members       Member[]
  invites       HouseholdInvite[]
  bonusRewards  BonusReward[]
  familyGoals   FamilyGoal[]
  tasks         HouseholdTask[]
  shoppingItems ShoppingItem[]
  bonusTransactions BonusTransaction[]
  bonusPurchases BonusPurchase[]
  monthlyReports MonthlyReport[]
}

model Member {
  id             String    @id @default(cuid())
  householdId    String
  telegramUserId String?   @unique
  chatId         String?   @unique
  firstName      String
  lastName       String?
  username       String?
  role           String    @default("member")
  isActive       Boolean   @default(true)
  joinedAt       DateTime  @default(now())
  leftAt         DateTime?
  experiencePoints Int     @default(0)
  level          Int       @default(0)
  bonusBalanceUnits Int    @default(0)
  completedTasksCount Int  @default(0)
  fastTasksCount   Int     @default(0)
  overdueTasksCount Int    @default(0)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  household      Household @relation(fields: [householdId], references: [id], onDelete: Cascade)
  bonusTransactions BonusTransaction[]
  bonusPurchases BonusPurchase[]
  createdInvites HouseholdInvite[] @relation("InviteCreator")
  createdBonusRewards BonusReward[] @relation("RewardCreator")
  createdFamilyGoals FamilyGoal[]  @relation("GoalCreator")

  @@index([householdId, isActive])
}

model HouseholdTask {
  id                String    @id @default(cuid())
  householdId       String
  title             String
  note              String?
  status            String    @default("open")
  priority          String    @default("normal")
  addedByName       String
  addedByUsername   String?
  addedByTelegramId String?
  deadlineAt        DateTime  @default(dbgenerated("(now() + interval '24 hours')"))
  completedAt       DateTime?
  completedByName   String?
  lastDeadlineReminderAt DateTime?
  penaltyAppliedAt  DateTime?
  penaltyAppliedUnits Int @default(0)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  household         Household @relation(fields: [householdId], references: [id], onDelete: Cascade)
  bonusTransactions BonusTransaction[]

  @@index([householdId, status, createdAt])
  @@index([householdId, status, deadlineAt])
}

model ShoppingItem {
  id                String    @id @default(cuid())
  householdId       String
  title             String
  status            String    @default("active")
  urgency           String    @default("soon")
  quantityLabel     String?
  note              String?
  addedByName       String
  addedByUsername   String?
  addedByTelegramId String?
  purchasedAt       DateTime?
  purchasedByName   String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  household         Household @relation(fields: [householdId], references: [id], onDelete: Cascade)

  @@index([householdId, status, createdAt])
}

model BonusTransaction {
  id          String        @id @default(cuid())
  householdId String
  memberId    String
  taskId      String?
  purchaseId  String?
  monthKey    String
  kind        String
  amountUnits Int
  note        String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  household   Household     @relation(fields: [householdId], references: [id], onDelete: Cascade)
  member      Member        @relation(fields: [memberId], references: [id], onDelete: Cascade)
  task        HouseholdTask? @relation(fields: [taskId], references: [id], onDelete: SetNull)
  purchase    BonusPurchase? @relation(fields: [purchaseId], references: [id], onDelete: SetNull)

  @@index([householdId, monthKey, memberId])
  @@index([taskId, kind])
}

model BonusPurchase {
  id          String      @id @default(cuid())
  householdId String
  memberId    String
  monthKey    String
  rewardKey   String
  rewardTitle String
  costUnits   Int
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  household   Household   @relation(fields: [householdId], references: [id], onDelete: Cascade)
  member      Member      @relation(fields: [memberId], references: [id], onDelete: Cascade)
  transactions BonusTransaction[]

  @@index([householdId, monthKey, memberId])
}

model BonusReward {
  id                String    @id @default(cuid())
  householdId       String
  createdByMemberId String
  title             String
  description       String?
  costUnits         Int
  isArchived        Boolean   @default(false)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  household         Household @relation(fields: [householdId], references: [id], onDelete: Cascade)
  createdByMember   Member    @relation("RewardCreator", fields: [createdByMemberId], references: [id], onDelete: Cascade)

  @@index([householdId, isArchived, createdAt])
}

model FamilyGoal {
  id                String    @id @default(cuid())
  householdId       String
  createdByMemberId String
  kind              String
  title             String
  description       String?
  targetValue       Int
  currentValue      Int       @default(0)
  unitLabel         String?
  isActive          Boolean   @default(true)
  completedAt       DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  household         Household @relation(fields: [householdId], references: [id], onDelete: Cascade)
  createdByMember   Member    @relation("GoalCreator", fields: [createdByMemberId], references: [id], onDelete: Cascade)

  @@index([householdId, isActive, createdAt])
}

model HouseholdInvite {
  id                 String    @id @default(cuid())
  householdId        String
  createdByMemberId  String
  code               String    @unique
  expiresAt          DateTime
  usedAt             DateTime?
  revokedAt          DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  household          Household @relation(fields: [householdId], references: [id], onDelete: Cascade)
  createdByMember    Member    @relation("InviteCreator", fields: [createdByMemberId], references: [id], onDelete: Cascade)

  @@index([householdId, expiresAt])
}

model ActionRateLimit {
  key             String   @id
  action          String
  scope           String
  hits            Int      @default(0)
  windowStartedAt DateTime
  blockedUntil    DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([action, scope])
  @@index([blockedUntil])
}

model MonthlyReport {
  id            String   @id @default(cuid())
  householdId   String
  monthKey      String
  title         String
  reportBody    String
  sentAt        DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  household     Household @relation(fields: [householdId], references: [id], onDelete: Cascade)

  @@unique([householdId, monthKey])
  @@index([householdId, createdAt])
}
